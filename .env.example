# ═══════════════════════════════════════════════════════════════════════════════
#                    TREND ROBOT - KONFIGURATSIYA
# ═══════════════════════════════════════════════════════════════════════════════
# EMA Crossover + Ichimoku Cloud confirmation + ADX filter.
# Trend-following strategiya — kuchli trendli bozorlarda ishlaydi.
#
# Barcha sozlamalar .env faylida yoki OS environment variables orqali.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────────────────────
SERVER_PORT=8090
BOT_ID=trend-v1
BOT_NAME=Trend Robot
BOT_VERSION=1.0.0

# HEMA platformasi bilan HMAC-SHA256 autentifikatsiya
BOT_SECRET=change-me-in-production
ADMIN_API_KEY=change-me-in-production

# Development uchun (production da False!)
ALLOW_INSECURE=false

# CORS
CORS_ALLOWED_ORIGINS=https://hema.trading,http://localhost:3000

# Docker internal webhook URL
# INTERNAL_WEBHOOK_HOST=http://hema:3000

# ─── BITGET API ───────────────────────────────────────────────────────────────
BITGET_API_KEY=your_api_key
BITGET_SECRET_KEY=your_secret_key
BITGET_PASSPHRASE=your_passphrase

# Demo rejim
DEMO_MODE=true

# ─── TRADING ──────────────────────────────────────────────────────────────────
TRADING_SYMBOL=BTCUSDT
LEVERAGE=10
MARGIN_MODE=crossed

# ─── EMA SOZLAMALARI ─────────────────────────────────────────────────────────
# Tez EMA davri (qisqa muddat)
EMA_FAST_PERIOD=9

# Sekin EMA davri (uzoq muddat)
EMA_SLOW_PERIOD=21

# ─── ICHIMOKU SOZLAMALARI ────────────────────────────────────────────────────
# Ichimoku Cloud yoqish/o'chirish
USE_ICHIMOKU=true

# Tenkan-sen (Conversion Line) davri
TENKAN_PERIOD=9

# Kijun-sen (Base Line) davri
KIJUN_PERIOD=26

# Senkou Span B (Cloud) davri
SENKOU_B_PERIOD=52

# Cloud displacement (kelajakka surilish)
DISPLACEMENT=26

# ─── MULTI-TIMEFRAME ─────────────────────────────────────────────────────────
# Multi-timeframe tasdiqlash yoqish
USE_MTF=true

# Asosiy signal timeframe
PRIMARY_TIMEFRAME=5m

# Tasdiqlash timeframe (o'rta)
CONFIRM_TIMEFRAME=15m

# Yuqori timeframe (katta rasm)
HTF_TIMEFRAME=1H

# ─── TREND KUCH FILTRI ───────────────────────────────────────────────────────
# ADX (Average Directional Index) davri
ADX_PERIOD=14

# ADX threshold (bu qiymatdan past bo'lsa signal bloklanadi)
# 25 = kuchli trend, 20 = o'rta trend
ADX_THRESHOLD=25

# ─── EXIT SOZLAMALARI ────────────────────────────────────────────────────────
# Trailing stop 3-bosqichli:
# 1. None — trailing faol emas
# 2. Breakeven — profit ACTIVATION% ga yetganda SL break-even ga ko'tariladi
# 3. Trail — profit davom etsa SL narx ortidan harakatlanadi

# Trailing stop yoqish
USE_TRAILING_STOP=true

# Qaysi profit % da trailing boshlanadi
TRAILING_ACTIVATE_PCT=1.0

# Minimal saqlanadigan profit (breakeven floor)
TRAILING_FLOOR_PCT=0.3

# Qarama-qarshi signal bilan chiqish (EMA death cross = LONG exit)
USE_OPPOSITE_SIGNAL_EXIT=true

# Stop loss (% sifatida, 0=o'chirilgan)
SL_PERCENT=3.0

# ─── TREND GRID (IXTIYORIY) ──────────────────────────────────────────────────
# Kuchli trend da martingale grid qo'shish
USE_TREND_GRID=false

# Grid multiplikatoru
GRID_MULTIPLIER=1.5

# Maksimal grid orderlar
GRID_MAX_ORDERS=5

# Trend grid uchun minimal ADX (ADX_THRESHOLD dan yuqori bo'lishi kerak)
GRID_MIN_ADX=35

# ─── RISK BOSHQARUVI ─────────────────────────────────────────────────────────
MAX_LOSS_PERCENT=20
MAX_DAILY_LOSS_PERCENT=10

# ─── FEE SOZLAMALARI ─────────────────────────────────────────────────────────
TAKER_FEE_RATE=0.001
MAKER_FEE_RATE=0.001

# ─── VAQT SOZLAMALARI ────────────────────────────────────────────────────────
TICK_INTERVAL=1.0
STATE_DIR=/data/state
LOG_LEVEL=INFO
